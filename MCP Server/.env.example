# SAP S/4HANA Cloud — copy to `.env` and adjust secrets locally (do not commit `.env`)

SAP_BASE_URL=https://my200967-api.s4hana.sapcloud.cn
SAP_CLIENT=100
SAP_CREDENTIALS_FILE=../user.txt
SAP_SCENARIO_DIR=..

MCP_PORT=3000
MCP_BIND_ADDRESS=127.0.0.1
MCP_ENABLE_HTTP_TRANSPORT=true
MCP_API_KEY=change-me
MCP_REQUIRE_API_KEY=false

SAP_REQUEST_TIMEOUT_MS=30000
SAP_CACHE_TTL_MS=0
