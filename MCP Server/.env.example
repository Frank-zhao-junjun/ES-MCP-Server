# ── SAP S/4HANA MCP Server — Environment Variables ──
# Copy to .env and fill in real values.
# Docker:  docker run --env-file .env ...
# Local:   set in mcp.json env block or your shell.

# ── Required ────────────────────────────────────────

# Pre-shared API key that Agents must present on every session.
MCP_API_KEY=mcp-your-real-key-here

# Path to the SAP communication user credential file.
# Format: User Name:<value> / 密码：<value>
SAP_CREDENTIALS_FILE=../user.txt

# Directory containing SAP_COM_xxxx endpoint text files.
SAP_SCENARIO_DIR=..

# ── SAP Connectivity ────────────────────────────────

# SAP S/4HANA Cloud API base URL (REQUIRED).
# Example: https://my200967-api.s4hana.sapcloud.cn
SAP_BASE_URL=https://your-tenant-api.s4hana.sapcloud.cn

# SAP client (default: 100).
# SAP_CLIENT=100

# SAP HTTP request timeout in ms (default: 30000).
# SAP_REQUEST_TIMEOUT_MS=30000

# ── Security ────────────────────────────────────────

# Require an explicit API key. In production this should always be true.
# When false, a temporary key is generated (dev only!).
MCP_REQUIRE_API_KEY=true

# ── Role / Tool Access ──────────────────────────────

# Agent role: readonly | debug | admin
#   readonly — business read-only tools only (default)
#   debug    — + query_sap_scenario debug tool
#   admin    — + plugin management (load/unload/list)
MCP_ROLE=readonly

# Explicit overrides (take precedence over MCP_ROLE):
# MCP_ENABLE_DEBUG_TOOLS=false
# MCP_ENABLE_ADMIN_TOOLS=false

# ── Rate Limiting ───────────────────────────────────

# Max concurrent SAP HTTP calls (default: 5).
# MCP_SAP_MAX_CONCURRENT=5

# Max SAP calls per minute (default: 60).
# MCP_SAP_RATE_PER_MIN=60

# ── v0.4 Features ───────────────────────────────────

# Multi-key authentication (JSON format). Overrides single MCP_API_KEY.
# MCP_API_KEYS={"key1": "readonly", "key2": "admin"}

# SAP response cache TTL in ms (0 = disabled, 300000 = 5min).
# SAP_CACHE_TTL_MS=0

# Auto-pagination max records (0 = disabled, hard cap 5000).
# MCP_AUTO_PAGE_MAX=0

# Prometheus metrics sidecar port (0 = disabled).
# MCP_METRICS_PORT=0

# ── v0.5 Features: HTTP/SSE Transport ───────────────

# Enable HTTP/SSE transport (default: false = stdio mode).
# When true, starts an HTTP server for MCP Streamable HTTP protocol.
# MCP_ENABLE_HTTP_TRANSPORT=false

# HTTP server port (default: 3000).
# MCP_PORT=3000

# HTTP server bind address (default: 127.0.0.1).
# Use 0.0.0.0 to listen on all interfaces (Docker/K8s).
# MCP_BIND_ADDRESS=127.0.0.1

# ── v0.5 Features: Admin Dashboard ──────────────────

# Admin dashboard password. If not set, admin dashboard is disabled.
# Access at http://localhost:<MCP_PORT>/admin
# MCP_ADMIN_PASSWORD=

# Admin session TTL in ms (default: 3600000 = 1 hour).
# MCP_ADMIN_SESSION_TTL=3600000

# ── Observability ───────────────────────────────────

# All structured logs go to stderr with JSON fields:
#   timestamp, level, requestId, traceId, tool, durationMs, status, error, sapCalls
